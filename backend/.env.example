# ============================
# 应用配置
# ============================
APP_NAME=ai-resume-analyzer          # 应用名称
APP_ENV=development                   # 运行环境: development / production
APP_DEBUG=true                        # 调试模式: true / false
API_PREFIX=/api/v1                    # API 路由前缀

# ============================
# AI 模型配置（必填）
# ============================
AI_PROVIDER=openai_compatible         # 模型供应商标识
AI_API_KEY=your_xiaomi_api_key_here   # 小米 MiMo API 密钥（必填，不可提交到 Git）
AI_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1  # API 基础地址
AI_MODEL_NAME=mimo-v2.5-pro           # 模型名称
AI_TIMEOUT=30                         # AI 调用超时时间（秒）

# ============================
# 缓存配置
# ============================
CACHE_ENABLED=true                    # 是否启用缓存: true / false（关闭后降级为实时计算）
REDIS_URL=redis://localhost:6379/0    # Redis 连接地址

# ============================
# 存储配置
# ============================
STORAGE_DRIVER=local                  # 存储驱动: local
UPLOAD_DIR=./storage/uploads          # 上传文件保存目录

# ============================
# 数据库配置
# ============================
DATABASE_URL=sqlite:///./storage/app.db  # 数据库连接地址（MVP 使用 SQLite）

# ============================
# 跨域配置
# ============================
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000  # 允许的前端域名（逗号分隔）
